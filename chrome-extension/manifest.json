{
  "manifest_version": 3,
  "name": "SaveTax 홈택스 자동 로그인",
  "version": "1.8",
  "description": "세무 업무 관리 시스템 - 홈택스 자동 로그인",
  "permissions": ["debugger", "downloads"],
  "host_permissions": ["http://158.247.222.58/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://hometax.go.kr/*"],
      "js": ["suppress-alert.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://hometax.go.kr/*"],
      "js": ["content-hometax.js"],
      "run_at": "document_idle"
    }
  ]
}
